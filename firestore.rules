rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Portfolio data should be publicly readable, so viewers can see it.
    match /portfolios/{portfolioId} {
      allow read: if true;
      
      // Only authenticated users (the owner) should be able to write/update it.
      allow write: if request.auth != null;
    }
  }
}
